    {
        "id": "fedac26e2fc5260f",
        "type": "function",
        "z": "8cc612c1ed61868c",
        "name": "Parseaza INA219",
        "func": "var d = msg.payload;\n\nvar msgs = [];\nmsgs.push({payload: parseFloat(d.voltage_V.toFixed(3))});\nmsgs.push({payload: parseFloat(d.current_mA.toFixed(2))});\nmsgs.push({payload: parseFloat(d.power_mW.toFixed(2))});\nmsgs.push({payload: parseFloat(d.shunt_mV.toFixed(3))});\n\nreturn [msgs[0], msgs[1], msgs[2], msgs[3]];",
        "outputs": 4,
        "x": 670,
        "y": 540,
        "wires": [
