    {
        "id": "4fb1107ad0cb060f",
        "type": "function",
        "z": "8cc612c1ed61868c",
        "name": "Parseaza Camera 1",
        "func": "var d = msg.payload;\nflow.set('cam1', d);\n\n// Trimite mesaje separate pentru fiecare widget\nvar msgs = [];\n\n// Stare lumina\nmsgs.push({topic:'cam1_on',    payload: d.on ? 'PORNITA' : 'OPRITA'});\nmsgs.push({topic:'cam1_locked', payload: d.locked ? 'DA' : 'NU'});\nmsgs.push({topic:'cam1_motion', payload: d.motion ? 'DA' : 'NU'});\nmsgs.push({topic:'cam1_pir',    payload: d.pir_raw ? 'ACTIV' : 'INACTIV'});\nmsgs.push({topic:'cam1_ldr',    payload: d.ldr});\nmsgs.push({topic:'cam1_pwm',    payload: d.pwm_pct});\n\n// Culoare indicator lumina\nmsgs[0].color = d.on ? '#4CAF50' : '#9E9E9E';\nmsgs[2].color = d.motion ? '#FF9800' : '#9E9E9E';\n\nreturn [msgs[0], msgs[1], msgs[2], msgs[3], msgs[4], msgs[5]];",
        "outputs": 6,
        "x": 360,
        "y": 500,
        "wires": [
            [
                "b924748e2dc9ef69"
            ],
            [
                "9c2a86071eba9e16"
            ],
            [
                "ae21e7e90874e3ac"
            ],
