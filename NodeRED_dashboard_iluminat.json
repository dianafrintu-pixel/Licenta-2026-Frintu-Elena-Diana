    },
    {
        "id": "189bd522449c8840",
        "type": "function",
        "z": "8cc612c1ed61868c",
        "name": "Parseaza Camera 2",
        "func": "var d = msg.payload;\nflow.set('cam2', d);\n\nvar msgs = [];\nmsgs.push({topic:'cam2_on',    payload: d.on ? 'PORNITA' : 'OPRITA'});\nmsgs.push({topic:'cam2_locked', payload: d.locked ? 'DA' : 'NU'});\nmsgs.push({topic:'cam2_motion', payload: d.motion ? 'DA' : 'NU'});\nmsgs.push({topic:'cam2_pir',    payload: d.pir_raw ? 'ACTIV' : 'INACTIV'});\nmsgs.push({topic:'cam2_ldr',    payload: d.ldr});\nmsgs.push({topic:'cam2_pwm',    payload: d.pwm_pct});\n\nreturn [msgs[0], msgs[1], msgs[2], msgs[3], msgs[4], msgs[5]];",
        "outputs": 6,
